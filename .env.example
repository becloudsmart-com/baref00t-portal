# ── baref00t platform ────────────────────────────────────────────────────
BAREF00T_API_KEY=pk_live_...                       # from baref00t hosted dashboard
BAREF00T_API_BASE=https://api.baref00t.io          # default; override only for staging tests

# ── NextAuth ─────────────────────────────────────────────────────────────
AUTH_SECRET=                                       # 32+ random bytes (use `openssl rand -base64 32`)
AUTH_URL=https://portal.partner.com                # external URL the portal is reachable at

# ── Partner's own Microsoft Entra app ────────────────────────────────────
# One Entra app reg in your tenant; used for both SSO + Mail.Send.
AZURE_AD_TENANT_ID=                                # your tenant GUID
AZURE_AD_CLIENT_ID=                                # your app reg GUID
AZURE_AD_CLIENT_SECRET=                            # client secret value

# ── Branding (env-driven theme) ──────────────────────────────────────────
BRAND_NAME="Acme Cloud Security"
BRAND_PRIMARY_COLOR=#00cc66                        # 6-digit hex
BRAND_LOGO_URL=https://cdn.acme.com/logo.svg       # full URL
BRAND_FAVICON_URL=https://cdn.acme.com/favicon.ico
BRAND_FOOTER_TEXT=© 2026 Acme Cloud Security
BRAND_CONTACT_EMAIL=security@acme.com
BRAND_THEME=dark                                   # dark | light

# ── Outbound mail (Microsoft Graph SendMail) ─────────────────────────────
# Optional. If MAIL_FROM_ADDRESS is unset, all outbound mail is a no-op.
# The app reg above must have Mail.Send (Application) permission and
# admin consent in your tenant. See docs/MAIL-SETUP.md.
MAIL_FROM_ADDRESS=security-no-reply@acme.com
MAIL_FROM_DISPLAY_NAME=Acme Security Reports

# ── Optional ─────────────────────────────────────────────────────────────
LOG_LEVEL=info                                     # trace | debug | info | warn | error | fatal
PORT=3000
NODE_ENV=production
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otlp.example.com
